{
    "name": "hms/core",
    "description": "Hospitality Management System Core Backend",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2 || ^8.3",
        "slim/slim": "^4.13",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "robmorgan/phinx": "^0.16.2",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "platform": {
            "php": "8.3.32"
        }
    }
}
